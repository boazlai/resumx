{
	"name": "@resumx/docs",
	"private": true,
	"type": "module",
	"scripts": {
		"codegen": "node -e \"const fs=require('fs'),p=require('path');fs.mkdirSync('public/schemas',{recursive:true});fs.readdirSync('../schemas').filter(f=>f.endsWith('.schema.json')).forEach(f=>fs.copyFileSync(p.join('../schemas',f),p.join('public/schemas',f)))\"",
		"dev": "pnpm run codegen && vitepress dev .",
		"build": "pnpm run codegen && vitepress build .",
		"preview": "vitepress preview ."
	},
	"dependencies": {
		"@vercel/analytics": "^1.6.1",
		"geist": "^1.7.0",
		"gsap": "^3.14.2",
		"lenis": "^1.3.18",
		"posthog-js": "^1.360.0",
		"shiki": "^4.0.2"
	},
	"devDependencies": {
		"@shikijs/transformers": "^3.22.0",
		"vite": "^7.3.1",
		"vitepress": "^2.0.0-alpha.15",
		"vue": "^3.5.30"
	}
}
